# Copy to .env and fill values used by gateway.py + crew.py

# HuggingFace logical id (must match vLLM --served-model-name below)
MODEL_NAME=texttinyllama

# vLLM OpenAI base URL (no trailing slash) — gateway forwards here.
# Lambda Cloud + README SSH tunnel: http://127.0.0.1:8000
VLLM_BASE_URL=http://127.0.0.1:8000

# TLS verify for HTTPS upstream only (not used for http://)
VLLM_TLS_VERIFY=true

# Labels metrics/traces (match your vLLM run / experiment arm)
VLLM_SERVER_PROFILE=baseline

# Optional: per-technique upstream URLs JSON (keys = crew.py --technique). Overrides auto routing below.
# Parallel server A/B (scripts/run_server_ab.sh parallel), e.g.:
# VLLM_BACKEND_MAP_JSON={"ab_baseline":"http://127.0.0.1:8000","ab_chunked_prefill":"http://127.0.0.1:8001","ab_prefix_caching":"http://127.0.0.1:8002"}
#
# Auto-pick upstream by --technique (no JSON): gateway maps to VLLM_BASE_URL host with ports 8000..8005
# (baseline+beam_search → base port, +1 chunked_prefill, +2 prefix_caching, +3 combined, +4 baseline_strict, +5 speculative).
# On the GPU host run: bash scripts/vllm_engine/run_engine_fleet.sh — then SSH-tunnel every port (README).
# Engine flags are not OpenAI request fields; this routes to different vLLM processes.
# VLLM_AUTO_ENGINE_ROUTING=1

# Fallback $/hour for gateway cost metrics if Lambda API lookup is off or fails
GPU_HOURLY_COST_USD=2.5

# --- Lambda Cloud API (optional — gateway cost metrics) ---
# Paste your secret key from Lambda dashboard → API keys. Docs: https://docs.lambda.ai/api/cloud
# When set, the gateway calls Lambda’s /instance-types prices on startup (unless LAMBDA_COST_USE_API=false).
LAMBDA_CLOUD_API_KEY=
# Instance type id for pricing, e.g. gpu_1x_a10 (same as launch wizard). Leave empty to infer from your running instance.
LAMBDA_INSTANCE_TYPE=
# true = use Lambda API when LAMBDA_CLOUD_API_KEY is set; false = always use GPU_HOURLY_COST_USD above
LAMBDA_COST_USE_API=true

# Gateway binds here (crew uses this full OpenAI base URL)
GATEWAY_HOST=127.0.0.1
GATEWAY_PORT=8765
GATEWAY_OPENAI_BASE=http://127.0.0.1:8765/v1

# crew.py polls GET /v1/models before kickoff (seconds; 0 = skip)
# CREW_VLLM_WAIT_S=240
# CREW_VLLM_POLL_S=8

# Crew LLM streaming (default true) → LiteLLM sends stream:true; gateway uses SSE and logs inter_chunk_* / histograms
# CREW_LLM_STREAM=false

# Prometheus metrics for the gateway (custom cost + technique labels)
GATEWAY_METRICS_PORT=9101
# Per-request JSONL (default if unset: repo logs/gateway/). Set to - to disable file logging.
# GATEWAY_METRICS_LOG_DIR=logs/gateway

# OpenTelemetry — gateway + crew export here
# Jaeger all-in-one OTLP gRPC:
OTEL_EXPORTER_OTLP_ENDPOINT=http://127.0.0.1:4317
OTEL_EXPORTER_OTLP_TRACES_ENDPOINT=http://127.0.0.1:4317
OTEL_SERVICE_NAME=gateway
# crew.py sets OTEL_SERVICE_NAME for the crew process only (Jaeger shows crew vs gateway).
# OTEL_SERVICE_NAME_CREW=crewai
# Use otlp when Jaeger is running (docker … -p 4317:4317). Use none if not — avoids OTLP UNAVAILABLE spam.
OTEL_TRACES_EXPORTER=none

# CrewAI native tracing (OpenTelemetry-compatible); OTLP export attaches to the same global provider
CREWAI_TRACING_ENABLED=true
